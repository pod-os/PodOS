{
  "compilerOptions": {
    "rootDir": "./src",
    "types": ["node"],
    "declaration": true,
    "target": "esnext",
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": ["esnext", "webworker"]
  },
  "exclude": ["**/*.spec.ts"]
}
