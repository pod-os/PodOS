// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`BrokenFile > renders 1`] = `
<div
  __self="[object global]"
  __source="[object Object]"
>
  <a
    __self="[object global]"
    __source="[object Object]"
    class="error"
    href="https://pod.test/image.png"
  >
    <div
      __self="[object global]"
      __source="[object Object]"
    >
      <sl-icon name="lock"></sl-icon>
    </div>
    <div
      __self="[object global]"
      __source="[object Object]"
      class="code"
    >
      401
    </div>
    <div
      __self="[object global]"
      __source="[object Object]"
      class="text"
    >
      unauthenticated
    </div>
  </a>
</div>
`;
