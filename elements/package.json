    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^30.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "happy-dom": "^20.10.2",
    "jest": "^30.3.0",
    "jest-cli": "^30.3.0",
    "jest-when": "^3.7.0",
    "msw": "^2.14.6",
    "prettier": "^3.5.3",
    "url-template": "^3.1.1",
    "vitest": "^4.1.8",
    "vitest-when": "^0.10.0"
