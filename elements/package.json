    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/markdown": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.1",
    "@uppy/image-editor": "^4.2.0",
    "@uppy/webcam": "^5.1.0",
    "@uvdsl/solid-oidc-client-browser": "^0.1.3",
    "idb": "^8.0.3",
    "neverthrow": "^8.2.0",
